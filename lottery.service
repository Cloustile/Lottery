[Unit]
Description=Lottery Web Application
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/lottery
ExecStart=/usr/bin/python3 /home/admin/lottery/app.py
Restart=always
RestartSec=10
StandardOutput=append:/home/admin/lottery/lottery.log
StandardError=append:/home/admin/lottery/lottery_error.log

# 环境变量
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target
